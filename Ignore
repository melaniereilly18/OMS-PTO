        <table style="font-size:12px;margin-bottom:14px;width:100%">
          <tr><td class="mono" style="padding:4px 0;color:var(--blue);width:80px">0.0385</td><td style="color:var(--muted)">~1 hr PTO per 26 hrs worked</td></tr>
          <tr><td class="mono" style="padding:4px 0;color:var(--blue)">0.0577</td><td style="color:var(--muted)">~1.5 hrs per 26 hrs worked</td></tr>
          <tr><td class="mono" style="padding:4px 0;color:var(--blue)">0.0769</td><td style="color:var(--muted)">~2 hrs per 26 hrs worked</td></tr>
        </table>
        <div class="form-grid-2">
          <div><label class="lbl">Accrual Rate</label><input type="number" id="rateInput" step="0.0001" placeholder="e.g. 0.0385"></div>
          <div style="display:flex;align-items:flex-end"><button class="btn btn-primary btn-full" onclick="updateRate()">Update</button></div>
