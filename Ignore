</div>

<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
// ===== DATA =====
let db = { employees: [], ptoRate: 0.0385, adminPassword: "sits2026" };
let currentEmpId = null;

function load() {
  try { const s = localStorage.getItem("sits_pto_v3"); if (s) db = {...db, ...JSON.parse(s)}; } catch(e) {}
}
function save() {
  try { localStorage.setItem("sits_pto_v3", JSON.stringify(db)); } catch(e) {}
}
load();

// ===== NAV =====
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if (id === 'admin') refreshAdmin();
  if (id === 'empLogin') refreshEmpLoginDropdown();
}

function switchTab(id, btn) {
  const parent = btn.closest('.page');
  parent.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  parent.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
  if (id === 'aPTO') renderAdminPending();
  if (id === 'aRollover') renderUpcomingRollovers();
}

// ===== ADMIN LOGIN =====
function doAdminLogin() {
  const pw = document.getElementById('adminPwInput').value;
  const err = document.getElementById('adminLoginErr');
  if (pw === db.adminPassword) {
    err.style.display = 'none';
    document.getElementById('adminPwInput').value = '';
    showPage('admin');
  } else {
    err.style.display = 'block';
    err.textContent = 'Incorrect password. Please try again.';
  }
}

// ===== EMPLOYEE LOGIN =====
function refreshEmpLoginDropdown() {
  const sel = document.getElementById('empLoginName');
  sel.innerHTML = '<option value="">Select your name...</option>' +
    db.employees.map(e => `<option value="${e.id}">${e.name}</option>`).join('');
  document.getElementById('empLoginPw').value = '';
  document.getElementById('empLoginErr').style.display = 'none';
}

function doEmpLogin() {
  const id = parseInt(document.getElementById('empLoginName').value);
  const pw = document.getElementById('empLoginPw').value;
  const err = document.getElementById('empLoginErr');
  const emp = db.employees.find(e => e.id === id);
  if (!emp || pw !== emp.password) {
    err.style.display = 'block';
    err.textContent = 'Incorrect name or password. Please try again.';
    return;
  }
  err.style.display = 'none';
  currentEmpId = id;
  document.getElementById('empLoginPw').value = '';
  showEmpDash(emp);
}

function logoutEmp() {
  currentEmpId = null;
  showPage('landing');
}

// ===== EMPLOYEE DASHBOARD =====
function showEmpDash(emp) {
  document.getElementById('empDashName').textContent = emp.name + "'s PTO";
  showPage('empDash');
  refreshEmpDash();
}

function refreshEmpDash() {
  const emp = db.employees.find(e => e.id === currentEmpId);
  if (!emp) return;
  document.getElementById('empProfileName').textContent = '👤 ' + emp.name;
  document.getElementById('empStatBalance').textContent = emp.ptoBalance.toFixed(2);
  document.getElementById('empStatHours').textContent = emp.hoursWorked.toFixed(0);
  document.getElementById('empStatRollover').textContent = '72';

  // Rollover info
  const info = document.getElementById('empRolloverInfo');
  if (emp.anniversaryDate) {
    const next = nextAnniversary(emp.anniversaryDate);
    const days = Math.ceil((new Date(next) - new Date()) / 86400000);
    info.textContent = `🗓️ Next PTO year anniversary: ${formatDate(next)} (${days} days away). Up to 72 hours will roll over; any excess hours will be forfeited.`;
  } else {
    info.textContent = 'No anniversary date set. Contact your Engagement Manager.';
  }

  // Pending requests
  const pending = (emp.requests || []).filter(r => r.status === 'Pending');
  const pendList = document.getElementById('empPendingList');
  pendList.innerHTML = pending.length ? pending.map(r => histItem(r)).join('') : '<div class="empty">No pending requests.</div>';

  // Full history
  const hist = document.getElementById('empFullHistory');
  const reqs = [...(emp.requests || [])].reverse();
  hist.innerHTML = reqs.length ? reqs.map(r => histItem(r)).join('') : '<div class="empty">No history yet.</div>';
}

function histItem(r) {
  const isAccrual = r.type === 'Accrual';
  const isRollover = r.type === 'Rollover';
  const cls = isAccrual ? 'accrual' : isRollover ? 'rollover' : r.status === 'Approved' ? 'used' : r.status === 'Pending' ? 'pending' : 'denied';
  const label = isAccrual ? '✅ PTO Accrued' : isRollover ? '🔄 Annual Rollover' : `🏖️ ${r.type === 'PTO Used' ? 'PTO Used' : 'PTO Request'} — ${r.status}`;
  const sign = (isAccrual || isRollover) ? '+' : '-';
  const hrsCls = (isAccrual || isRollover) ? 'pos' : r.status === 'Denied' ? 'neutral' : 'neg';
  const absHrs = Math.abs(r.hours);
  return `<div class="hist-item ${cls}">
    <div><div class="hist-meta">${label}</div><div class="hist-sub">${r.date}${r.note ? ' · ' + r.note : ''}</div></div>
    <div class="hist-hrs ${hrsCls}">${sign}${absHrs.toFixed(2)}h</div>
  </div>`;
}

// ===== PTO REQUEST + ESTIMATOR =====
function estimatePTO() {
  const emp = db.employees.find(e => e.id === currentEmpId);
  if (!emp) return;
  const hours = parseFloat(document.getElementById('reqHours').value);
  const startDate = document.getElementById('reqStartDate').value;
  const result = document.getElementById('estimatorResult');
  if (!hours || hours <= 0 || !startDate) { result.style.display = 'none'; return; }

  const daysUntil = Math.max(0, Math.ceil((new Date(startDate + 'T12:00:00') - new Date()) / 86400000));
  const hoursUntil = daysUntil * 8;
  const willAccrue = parseFloat((hoursUntil * db.ptoRate).toFixed(2));
  const projectedBalance = parseFloat((emp.ptoBalance + willAccrue).toFixed(2));
  const sufficient = projectedBalance >= hours;

  result.style.display = 'block';
  if (sufficient) {
    result.className = 'estimator-result alert alert-green';
    result.innerHTML = `✅ <strong>Estimated approval.</strong> Your projected balance on ${formatDate(startDate)} will be approximately <strong>${projectedBalance.toFixed(2)} hours</strong> (current ${emp.ptoBalance.toFixed(2)}h + ~${willAccrue}h accrual). This request for ${hours}h should be approved.`;
  } else {
    result.className = 'estimator-result alert alert-red';
    result.innerHTML = `⚠️ <strong>Insufficient balance.</strong> Your projected balance on ${formatDate(startDate)} will be approximately <strong>${projectedBalance.toFixed(2)} hours</strong>, which is less than the ${hours}h requested. This request will be denied unless you accrue more hours first.`;
  }
}

function submitPTORequest() {
  const emp = db.employees.find(e => e.id === currentEmpId);
  if (!emp) return;
  const hours = parseFloat(document.getElementById('reqHours').value);
  const startDate = document.getElementById('reqStartDate').value;
  const endDate = document.getElementById('reqEndDate').value || startDate;
  const note = document.getElementById('reqNote').value.trim() || 'Employee PTO request';
  if (!hours || hours <= 0 || !startDate) return alert('Please fill in the required fields.');

  const daysUntil = Math.max(0, Math.ceil((new Date(startDate + 'T12:00:00') - new Date()) / 86400000));
  const willAccrue = parseFloat((daysUntil * 8 * db.ptoRate).toFixed(2));
  const projectedBalance = parseFloat((emp.ptoBalance + willAccrue).toFixed(2));
  const sufficient = projectedBalance >= hours;
  const status = sufficient ? 'Approved' : 'Denied';

  if (sufficient) emp.ptoBalance = parseFloat((emp.ptoBalance - hours).toFixed(2));

  emp.requests = emp.requests || [];
  emp.requests.push({
    id: Date.now(), type: 'PTO Used', hours: -hours,
    date: formatDate(startDate) + (endDate !== startDate ? ' – ' + formatDate(endDate) : ''),
    note, status
  });

  save();
  refreshEmpDash();
  document.getElementById('reqHours').value = '';
  document.getElementById('reqStartDate').value = '';
  document.getElementById('reqEndDate').value = '';
  document.getElementById('reqNote').value = '';
  document.getElementById('estimatorResult').style.display = 'none';

  if (sufficient) {
    alert(`✅ Your PTO request for ${hours} hours has been automatically approved!`);
  } else {
    alert(`❌ Your PTO request for ${hours} hours was denied due to insufficient projected balance. Contact your Engagement Manager.`);
  }
}

function runEstimator() {
  const emp = db.employees.find(e => e.id === currentEmpId);
  if (!emp) return;
  const date = document.getElementById('estimateDate').value;
  const extraHours = parseFloat(document.getElementById('estimateHours').value) || 0;
  const out = document.getElementById('estimatorOutput');
  if (!date) { out.style.display = 'none'; return; }

  const daysUntil = Math.max(0, Math.ceil((new Date(date + 'T12:00:00') - new Date()) / 86400000));
  const willAccrue = parseFloat((daysUntil * 8 * db.ptoRate).toFixed(2));
  const projected = parseFloat((emp.ptoBalance + willAccrue - extraHours).toFixed(2));

  out.style.display = 'block';
  const cls = projected >= 0 ? 'alert-green' : 'alert-red';
  out.innerHTML = `<div class="alert ${cls}">
    On <strong>${formatDate(date)}</strong> (${daysUntil} days away):<br>
    Current balance: ${emp.ptoBalance.toFixed(2)}h + ~${willAccrue}h accrual${extraHours > 0 ? ` − ${extraHours}h request` : ''} = <strong>${projected.toFixed(2)}h projected balance</strong>
  </div>`;
}

// ===== EMPLOYEE PASSWORD CHANGE =====
function changeEmpPassword() {
  const emp = db.employees.find(e => e.id === currentEmpId);
  const cur = document.getElementById('empCurPw').value;
  const np = document.getElementById('empNewPw').value;
  const cp = document.getElementById('empConfirmPw').value;
  const msg = document.getElementById('empPwMsg');
  msg.style.display = 'block';
  if (cur !== emp.password) { msg.className = 'alert alert-red'; msg.textContent = 'Current password is incorrect.'; return; }
  if (!np) { msg.className = 'alert alert-red'; msg.textContent = 'Please enter a new password.'; return; }
  if (np !== cp) { msg.className = 'alert alert-red'; msg.textContent = 'New passwords do not match.'; return; }
  emp.password = np;
  save();
  document.getElementById('empCurPw').value = '';
  document.getElementById('empNewPw').value = '';
  document.getElementById('empConfirmPw').value = '';
  msg.className = 'alert alert-green';
  msg.textContent = '✅ Password updated successfully.';
}

// ===== ADMIN FUNCTIONS =====
function refreshAdmin() {
  document.getElementById('adminSubtitle').textContent = `${db.employees.length} employees · Rate: ${db.ptoRate} hrs/hr`;
  document.getElementById('empCount').textContent = db.employees.length;
  document.getElementById('rateDisplay').textContent = db.ptoRate;
  document.getElementById('rateInput').value = db.ptoRate;
  renderEmpTable();
  refreshAllDropdowns();
}

function renderEmpTable() {
  const tbody = document.getElementById('empTable');
  if (!db.employees.length) { tbody.innerHTML = '<tr><td colspan="6" class="empty">No employees yet.</td></tr>'; return; }
  tbody.innerHTML = db.employees.map(e => {
    const next = e.anniversaryDate ? nextAnniversary(e.anniversaryDate) : null;
    const days = next ? Math.ceil((new Date(next) - new Date()) / 86400000) : null;
    const rollBadge = days !== null ? `<span class="badge ${days <= 30 ? 'badge-orange' : 'badge-blue'}">${formatDate(next)} (${days}d)</span>` : '<span class="badge badge-yellow">Not set</span>';
    return `<tr>
      <td style="font-weight:600">${e.name}</td>
      <td>${e.anniversaryDate ? formatDate(e.anniversaryDate) : '—'}</td>
      <td class="mono">${e.hoursWorked.toFixed(1)}</td>
      <td><span class="badge ${e.ptoBalance >= 0 ? 'badge-green' : 'badge-red'}">${e.ptoBalance.toFixed(2)}h</span></td>
      <td>${rollBadge}</td>
      <td><button class="btn btn-danger btn-sm" onclick="removeEmployee(${e.id})">Remove</button></td>
    </tr>`;
  }).join('');
}

function refreshAllDropdowns() {
  const opts = '<option value="">Select employee...</option>' +
    db.employees.map(e => `<option value="${e.id}">${e.name} — ${e.ptoBalance.toFixed(2)}h</option>`).join('');
  ['accrualEmp','ptoEmp','rolloverEmp','pwEmp'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = opts;
  });
}

function addEmployee() {
  const name = document.getElementById('newName').value.trim();
  const anniv = document.getElementById('newAnniv').value;
  const balance = parseFloat(document.getElementById('newBalance').value) || 0;
  const pw = document.getElementById('newPw').value;
  if (!name) return alert('Please enter a name.');
  if (!pw) return alert('Please set a password for this employee.');
  db.employees.push({ id: Date.now(), name, anniversaryDate: anniv || null, hoursWorked: 0, ptoBalance: balance, password: pw, requests: [] });
  save();
  ['newName','newAnniv','newBalance','newPw'].forEach(id => document.getElementById(id).value = '');
  refreshAdmin();
}

function removeEmployee(id) {
  if (!confirm('Remove this employee? This cannot be undone.')) return;
  db.employees = db.employees.filter(e => e.id !== id);
  save(); refreshAdmin();
}

function previewAccrual() {
  const hours = parseFloat(document.getElementById('accrualHours').value);
  const weekEnd = document.getElementById('accrualWeekEnd').value;
  const empId = parseInt(document.getElementById('accrualEmp').value);
  const preview = document.getElementById('accrualPreview');
  const dupWarning = document.getElementById('accrualDupWarning');
  if (hours > 0 && weekEnd) {
    const accrued = (hours * db.ptoRate).toFixed(2);
    preview.style.display = 'block';
    preview.textContent = `✅ Week ending ${formatDate(weekEnd)}: ${hours} hrs worked will accrue ${accrued} hours of PTO`;
    // Check for duplicate week
    if (empId) {
      const emp = db.employees.find(e => e.id === empId);
      const weekLabel = 'Week ending ' + formatDate(weekEnd);
      const isDup = emp && emp.weeklyHours && emp.weeklyHours.some(w => w.weekEnd === weekEnd);
      if (isDup) {
        dupWarning.style.display = 'block';
        dupWarning.textContent = `⚠️ Hours for week ending ${formatDate(weekEnd)} have already been logged for this employee. Submitting will add an additional entry.`;
      } else { dupWarning.style.display = 'none'; }
    }
  } else { preview.style.display = 'none'; dupWarning.style.display = 'none'; }
}

function logHours() {
  const empId = parseInt(document.getElementById('accrualEmp').value);
  const hours = parseFloat(document.getElementById('accrualHours').value);
  const weekEnd = document.getElementById('accrualWeekEnd').value;
  if (!empId || !hours || hours <= 0 || !weekEnd) return alert('Please select an employee, enter hours, and select a week ending date.');
  const emp = db.employees.find(e => e.id === empId);
  const accrued = parseFloat((hours * db.ptoRate).toFixed(2));
  emp.hoursWorked = parseFloat((emp.hoursWorked + hours).toFixed(2));
  emp.ptoBalance = parseFloat((emp.ptoBalance + accrued).toFixed(2));
  // Store weekly entry
  if (!emp.weeklyHours) emp.weeklyHours = [];
  emp.weeklyHours.push({ id: Date.now(), weekEnd, hours, accrued });
  // Sort by weekEnd descending
  emp.weeklyHours.sort((a, b) => new Date(b.weekEnd) - new Date(a.weekEnd));
  emp.requests.push({ id: Date.now(), type: 'Accrual', hours: accrued, date: formatDate(weekEnd), note: `Week ending ${formatDate(weekEnd)}: ${hours} hrs worked`, status: 'Accrued' });
  save(); refreshAdmin();
  document.getElementById('accrualHours').value = '';
  document.getElementById('accrualWeekEnd').value = '';
  document.getElementById('accrualPreview').style.display = 'none';
  document.getElementById('accrualDupWarning').style.display = 'none';
  renderWeeklyLog();
  alert(`✅ Week ending ${formatDate(weekEnd)}: logged ${hours} hrs, accrued ${accrued} PTO hrs for ${emp.name}`);
}

function renderWeeklyLog() {
  const empId = parseInt(document.getElementById('accrualEmp').value);
  const nameEl = document.getElementById('weeklyEmpName');
  const logEl = document.getElementById('weeklyLog');
  if (!empId) { nameEl.textContent = 'Select an employee above'; logEl.innerHTML = '<div class="empty">Select an employee to view their weekly hours log.</div>'; return; }
  const emp = db.employees.find(e => e.id === empId);
  if (!emp) return;
  nameEl.textContent = emp.name;
  const weeks = emp.weeklyHours || [];
  if (!weeks.length) { logEl.innerHTML = '<div class="empty">No hours logged yet for this employee.</div>'; return; }
  const totalHours = weeks.reduce((s, w) => s + w.hours, 0);
  const totalAccrued = weeks.reduce((s, w) => s + w.accrued, 0);
  logEl.innerHTML = `
    <div style="overflow-x:auto">
      <table>
        <thead><tr><th>Week Ending</th><th>Hours Worked</th><th>PTO Accrued</th><th></th></tr></thead>
        <tbody>
          ${weeks.map(w => `<tr>
            <td style="font-weight:600">${formatDate(w.weekEnd)}</td>
            <td class="mono">${w.hours}</td>
            <td><span class="badge badge-green">+${w.accrued.toFixed(2)}h</span></td>
            <td><button class="btn btn-danger btn-sm" onclick="deleteWeekEntry(${emp.id}, ${w.id})">Delete</button></td>
          </tr>`).join('')}
        </tbody>
        <tfoot>
          <tr style="background:var(--bg);font-weight:700">
            <td style="padding:10px 12px;font-size:12px;color:var(--navy)">TOTAL (${weeks.length} weeks)</td>
            <td style="padding:10px 12px;font-family:'DM Mono',monospace">${totalHours.toFixed(1)}</td>
            <td style="padding:10px 12px"><span class="badge badge-blue">+${totalAccrued.toFixed(2)}h</span></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>`;
}

function deleteWeekEntry(empId, entryId) {
  if (!confirm('Delete this week entry? This will reverse the hours and PTO accrual.')) return;
  const emp = db.employees.find(e => e.id === empId);
  const entry = emp.weeklyHours.find(w => w.id === entryId);
  if (!entry) return;
  emp.hoursWorked = parseFloat(Math.max(0, emp.hoursWorked - entry.hours).toFixed(2));
  emp.ptoBalance = parseFloat((emp.ptoBalance - entry.accrued).toFixed(2));
  emp.weeklyHours = emp.weeklyHours.filter(w => w.id !== entryId);
  save(); refreshAdmin(); renderWeeklyLog();
}

function logPTO() {
  const empId = parseInt(document.getElementById('ptoEmp').value);
  const hours = parseFloat(document.getElementById('ptoHours').value);
  const date = document.getElementById('ptoDate').value;
  const status = document.getElementById('ptoStatus').value;
  const note = document.getElementById('ptoNote').value.trim() || 'Admin adjustment';
  if (!empId || !hours || !date) return alert('Please fill in all required fields.');
  const emp = db.employees.find(e => e.id === empId);
  if (status === 'Approved' && hours > emp.ptoBalance) return alert('Insufficient balance.');
  if (status === 'Approved') emp.ptoBalance = parseFloat((emp.ptoBalance - hours).toFixed(2));
  emp.requests.push({ id: Date.now(), type: 'PTO Used', hours: -hours, date: formatDate(date), note, status });
  save(); refreshAdmin();
  alert(`✅ PTO logged for ${emp.name} — ${status}`);
}

function renderAdminPending() {
  const list = document.getElementById('adminPendingList');
  const all = db.employees.flatMap(e => (e.requests || []).filter(r => r.status === 'Pending').map(r => ({...r, empName: e.name, empId: e.id})));
  list.innerHTML = all.length ? all.map(r => `
    <div class="hist-item pending" style="margin-bottom:8px">
      <div>
        <div class="hist-meta">🏖️ ${r.empName} — ${Math.abs(r.hours).toFixed(2)}h</div>
        <div class="hist-sub">${r.date} · ${r.note}</div>
      </div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-success btn-sm" onclick="updateRequestStatus(${r.empId},${r.id},'Approved')">Approve</button>
        <button class="btn btn-danger btn-sm" onclick="updateRequestStatus(${r.empId},${r.id},'Denied')">Deny</button>
      </div>
    </div>`).join('') : '<div class="empty">No pending requests.</div>';
}

function updateRequestStatus(empId, reqId, status) {
  const emp = db.employees.find(e => e.id === empId);
  const req = emp.requests.find(r => r.id === reqId);
  if (!req) return;
  if (status === 'Approved') {
    const hours = Math.abs(req.hours);
    if (hours > emp.ptoBalance) return alert('Insufficient balance to approve.');
    emp.ptoBalance = parseFloat((emp.ptoBalance - hours).toFixed(2));
  }
  req.status = status;
  save(); renderAdminPending(); refreshAdmin();
}

// ===== ROLLOVER =====
function nextAnniversary(dateStr) {
  const orig = new Date(dateStr + 'T12:00:00');
  const now = new Date();
  let next = new Date(orig);
  next.setFullYear(now.getFullYear());
  if (next <= now) next.setFullYear(now.getFullYear() + 1);
  return next.toISOString().split('T')[0];
}

function processRollover() {
  const empId = parseInt(document.getElementById('rolloverEmp').value);
  if (!empId) return alert('Please select an employee.');
  const emp = db.employees.find(e => e.id === empId);
  const ROLLOVER_CAP = 72;
  const current = emp.ptoBalance;
  const forfeited = Math.max(0, current - ROLLOVER_CAP);
  const newBalance = Math.min(current, ROLLOVER_CAP);
  emp.ptoBalance = parseFloat(newBalance.toFixed(2));
  emp.requests.push({
    id: Date.now(), type: 'Rollover',
    hours: forfeited > 0 ? -(forfeited) : 0,
    date: new Date().toLocaleDateString(),
    note: `Annual rollover. Balance capped at 72h. ${forfeited > 0 ? forfeited.toFixed(2) + 'h forfeited.' : 'No hours forfeited.'}`,
    status: 'Processed'
  });
  save(); refreshAdmin();
  const msg = document.getElementById('rolloverMsg');
  msg.style.display = 'block';
  msg.className = 'alert alert-green';
  msg.textContent = `✅ Rollover processed for ${emp.name}. Balance: ${current.toFixed(2)}h → ${newBalance.toFixed(2)}h. ${forfeited > 0 ? forfeited.toFixed(2) + 'h forfeited.' : 'No hours forfeited.'}`;
}

function renderUpcomingRollovers() {
  const div = document.getElementById('upcomingRollovers');
  if (!db.employees.length) { div.innerHTML = '<div class="empty">No employees yet.</div>'; return; }
  const sorted = db.employees
    .filter(e => e.anniversaryDate)
    .map(e => ({ emp: e, next: nextAnniversary(e.anniversaryDate) }))
    .sort((a, b) => new Date(a.next) - new Date(b.next));
  div.innerHTML = sorted.map(({emp, next}) => {
    const days = Math.ceil((new Date(next) - new Date()) / 86400000);
    const cls = days <= 14 ? 'badge-orange' : days <= 30 ? 'badge-yellow' : 'badge-blue';
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)">
      <div><div style="font-weight:600;font-size:14px">${emp.name}</div>
      <div style="font-size:12px;color:var(--muted)">Current balance: ${emp.ptoBalance.toFixed(2)}h ${emp.ptoBalance > 72 ? `(${(emp.ptoBalance - 72).toFixed(2)}h will be forfeited)` : ''}</div></div>
      <span class="badge ${cls}">${formatDate(next)} · ${days}d</span>
    </div>`;
  }).join('') || '<div class="empty">No anniversary dates set.</div>';
}

// ===== SETTINGS =====
function updateRate() {
  const rate = parseFloat(document.getElementById('rateInput').value);
  if (isNaN(rate) || rate <= 0) return alert('Invalid rate.');
  db.ptoRate = rate; save(); refreshAdmin();
  const msg = document.getElementById('rateMsg');
  msg.style.display = 'block'; msg.className = 'alert alert-green';
  msg.textContent = `✅ Rate updated to ${rate}`;
}

function resetEmpPw() {
  const empId = parseInt(document.getElementById('pwEmp').value);
  const pw = document.getElementById('pwNew').value;
  const msg = document.getElementById('pwResetMsg');
  msg.style.display = 'block';
  if (!empId || !pw) { msg.className = 'alert alert-red'; msg.textContent = 'Please select an employee and enter a password.'; return; }
  db.employees.find(e => e.id === empId).password = pw;
  save();
  document.getElementById('pwNew').value = '';
  msg.className = 'alert alert-green';
  msg.textContent = `✅ Password reset successfully.`;
}

function changeAdminPw() {
  const np = document.getElementById('adminNewPw').value;
  const cp = document.getElementById('adminConfirmPw').value;
  const msg = document.getElementById('adminPwMsg');
  msg.style.display = 'block';
  if (!np || np !== cp) { msg.className = 'alert alert-red'; msg.textContent = np ? 'Passwords do not match.' : 'Please enter a password.'; return; }
  db.adminPassword = np; save();
  document.getElementById('adminNewPw').value = '';
  document.getElementById('adminConfirmPw').value = '';
  msg.className = 'alert alert-green'; msg.textContent = '✅ Admin password updated.';
}

function exportCSV() {
  if (!db.employees.length) return alert('No data to export.');
  let csv = 'Name,Anniversary Date,Hours Worked,PTO Balance,Total Requests\n';
  db.employees.forEach(e => { csv += `"${e.name}",${e.anniversaryDate||''},${e.hoursWorked.toFixed(2)},${e.ptoBalance.toFixed(2)},${e.requests.length}\n`; });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv], {type:'text/csv'}));
  a.download = `SITS_PTO_${new Date().toLocaleDateString().replace(/\//g,'-')}.csv`;
  a.click();
}

function clearAll() {
  if (!confirm('Delete ALL data? This cannot be undone.')) return;
  if (!confirm('Are you absolutely sure?')) return;
  db.employees = []; save(); refreshAdmin();
}

