          <div><label class="lbl">Confirm</label><input type="password" id="adminConfirmPw" placeholder="Confirm"></div>
        </div>
        <button class="btn btn-primary" onclick="changeAdminPw()">Update Admin Password</button>
        <div id="adminPwMsg" style="display:none;margin-top:8px"></div>
      </div>

      <div class="card">
        <div class="card-title">💾 Data</div>
        <div class="form-grid-2">
          <button class="btn btn-secondary" onclick="exportCSV()">📥 Export to CSV</button>
