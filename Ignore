<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SITS PTO Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1a2f4a; --blue: #1e4d8c; --mid: #2d6abf; --light: #4a90d9;
    --accent: #5bbfdf; --bg: #f0f5fb; --card: #ffffff; --text: #1a2035;
    --muted: #6b7a99; --border: #dbe6f5; --radius: 12px;
    --shadow: 0 2px 12px rgba(30,77,140,0.08);
    --green: #0d7a4e; --green-bg: #e6f7f0; --green-border: #b7e8d4;
    --red: #c0392b; --red-bg: #fdecea; --red-border: #f5c6c2;
    --yellow: #8a5a00; --yellow-bg: #fff8e6; --yellow-border: #ffd97a;
    --orange: #9a4500; --orange-bg: #fff0e6; --orange-border: #ffbe8a;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
  .page { display: none; min-height: 100vh; padding: 24px; }
  .page.active { display: flex; flex-direction: column; align-items: center; }
  .container { width: 100%; max-width: 760px; }
  .container-sm { width: 100%; max-width: 460px; }

  /* HEADER */
  .header { background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 100%); border-radius: var(--radius); padding: 22px 28px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 20px rgba(26,47,74,0.25); }
  .header h1 { color: #fff; font-size: 17px; font-weight: 700; }
  .header p { color: var(--accent); font-size: 12px; margin-top: 3px; }

  /* LANDING */
  #landing { justify-content: center; background: linear-gradient(160deg, #e8f0fb 0%, #f5f8ff 50%, #eaf4fb 100%); }
  .landing-card { background: var(--card); border-radius: 20px; overflow: hidden; box-shadow: 0 8px 40px rgba(30,77,140,0.15); width: 100%; max-width: 440px; }
  .landing-hero { background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 60%, var(--mid) 100%); padding: 40px 32px; text-align: center; }
  .landing-logo { width: 64px; height: 64px; background: rgba(255,255,255,0.12); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 16px; border: 1px solid rgba(255,255,255,0.2); }
  .landing-hero h1 { color: #fff; font-size: 22px; font-weight: 700; }
  .landing-hero p { color: var(--accent); font-size: 13px; margin-top: 6px; }
  .landing-body { padding: 28px 32px 32px; }
  .landing-body > p { color: var(--muted); font-size: 13px; text-align: center; margin-bottom: 20px; }

  /* BUTTONS */
  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 18px; border: none; border-radius: 9px; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.15s; }
  .btn-primary { background: var(--blue); color: #fff; }
  .btn-primary:hover { background: var(--navy); transform: translateY(-1px); }
  .btn-secondary { background: var(--mid); color: #fff; }
  .btn-secondary:hover { background: var(--blue); }
  .btn-ghost { background: var(--bg); color: var(--muted); border: 1px solid var(--border); }
  .btn-ghost:hover { background: var(--border); }
  .btn-danger { background: var(--red-bg); color: var(--red); border: 1px solid var(--red-border); }
  .btn-danger:hover { background: #f9d5d2; }
  .btn-success { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); }
  .btn-sm { padding: 5px 10px; font-size: 12px; border-radius: 7px; }
  .btn-full { width: 100%; }
  .btn-back { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.2); font-size: 12px; padding: 6px 14px; }
  .btn-back:hover { background: rgba(255,255,255,0.22); color: #fff; }

  /* CARDS */
  .card { background: var(--card); border-radius: var(--radius); padding: 20px 24px; margin-bottom: 16px; box-shadow: var(--shadow); border: 1px solid var(--border); }
  .card-title { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }

  /* FORMS */
  label.lbl { display: block; font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 5px; }
  input, select { width: 100%; padding: 9px 13px; border: 1.5px solid var(--border); border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--text); background: #fff; outline: none; transition: border-color 0.15s; }
  input:focus, select:focus { border-color: var(--light); box-shadow: 0 0 0 3px rgba(74,144,217,0.12); }
  .form-row { margin-bottom: 14px; }
  .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px; }
  .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 14px; }
  .form-grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr auto; gap: 8px; align-items: end; margin-bottom: 14px; }

  /* TABS */
  .tabs { display: flex; gap: 4px; background: var(--card); border-radius: 10px; padding: 4px; margin-bottom: 20px; box-shadow: var(--shadow); border: 1px solid var(--border); flex-wrap: wrap; }
  .tab { flex: 1; min-width: 80px; padding: 8px 4px; border: none; border-radius: 7px; font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 600; cursor: pointer; color: var(--muted); background: transparent; transition: all 0.15s; }
  .tab.active { background: var(--blue); color: #fff; }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* TABLE */
  .tbl-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { padding: 9px 12px; text-align: left; font-size: 10px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid var(--border); background: var(--bg); }
  td { padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #fafcff; }

  /* BADGES */
  .badge { display: inline-flex; align-items: center; padding: 2px 9px; border-radius: 20px; font-size: 11px; font-weight: 700; }
  .badge-green { background: var(--green-bg); color: var(--green); }
  .badge-red { background: var(--red-bg); color: var(--red); }
  .badge-yellow { background: var(--yellow-bg); color: var(--yellow); }
  .badge-blue { background: #e8f0fb; color: var(--blue); }
  .badge-orange { background: var(--orange-bg); color: var(--orange); }

  /* STATS */
  .stats-grid { display: grid; gap: 12px; margin-bottom: 16px; }
  .stats-3 { grid-template-columns: 1fr 1fr 1fr; }
  .stats-2 { grid-template-columns: 1fr 1fr; }
  .stat-card { background: var(--card); border-radius: 10px; padding: 16px 18px; border: 1px solid var(--border); box-shadow: var(--shadow); text-align: center; }
  .stat-value { font-size: 26px; font-weight: 700; color: var(--navy); font-family: 'DM Mono', monospace; }
  .stat-label { font-size: 10px; color: var(--muted); margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

  /* HISTORY */
  .hist-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; border-radius: 9px; margin-bottom: 8px; border: 1px solid transparent; }
  .hist-item.accrual { background: var(--green-bg); border-color: var(--green-border); }
  .hist-item.used { background: var(--red-bg); border-color: var(--red-border); }
  .hist-item.pending { background: var(--yellow-bg); border-color: var(--yellow-border); }
  .hist-item.rollover { background: #e8f0fb; border-color: #c5d9f5; }
  .hist-item.denied { background: #f5f5f5; border-color: #ddd; }
  .hist-meta { font-size: 13px; font-weight: 600; }
  .hist-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .hist-hrs { font-size: 14px; font-weight: 700; font-family: 'DM Mono', monospace; }
  .hist-hrs.pos { color: var(--green); }
  .hist-hrs.neg { color: var(--red); }
  .hist-hrs.neutral { color: var(--blue); }

  /* ALERTS */
  .alert { padding: 11px 15px; border-radius: 9px; font-size: 13px; margin-bottom: 14px; font-weight: 500; border: 1px solid transparent; }
  .alert-green { background: var(--green-bg); color: var(--green); border-color: var(--green-border); }
  .alert-red { background: var(--red-bg); color: var(--red); border-color: var(--red-border); }
  .alert-yellow { background: var(--yellow-bg); color: var(--yellow); border-color: var(--yellow-border); }
  .alert-blue { background: #e8f0fb; color: var(--blue); border-color: #c5d9f5; }
  .alert-orange { background: var(--orange-bg); color: var(--orange); border-color: var(--orange-border); }

  /* MISC */
  .empty { text-align: center; color: var(--muted); font-size: 13px; padding: 24px 0; }
  .hint { color: var(--muted); font-size: 11px; margin-top: 5px; }
  .error { color: var(--red); font-size: 12px; margin-top: 6px; font-weight: 500; }
  hr { border: none; border-top: 1px solid var(--border); margin: 16px 0; }
  .mono { font-family: 'DM Mono', monospace; }
  .emp-profile { background: linear-gradient(135deg, #e8f2fb, #f5faff); border-radius: 10px; padding: 20px; border: 1px solid var(--border); margin-bottom: 16px; }
  .emp-name-lg { font-size: 19px; font-weight: 700; color: var(--navy); margin-bottom: 14px; }
  .section-divider { font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; margin: 20px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--border); }
  .rollover-info { font-size: 12px; color: var(--muted); padding: 8px 12px; background: var(--bg); border-radius: 7px; margin-top: 8px; }
  .estimator-result { padding: 14px 16px; border-radius: 10px; margin-top: 14px; }
</style>
</head>
<body>

<!-- ===== LANDING ===== -->
<div id="landing" class="page active">
  <div class="landing-card">
    <div class="landing-hero">
      <div class="landing-logo">📋</div>
      <h1>SITS PTO Tracker</h1>
      <p>Steelcase Integrated Talent Solutions</p>
    </div>
    <div class="landing-body">
      <p>Select your role to continue</p>
      <div style="display:flex;flex-direction:column;gap:10px">
        <button class="btn btn-primary btn-full" style="padding:13px;font-size:15px" onclick="showPage('adminLogin')">🔐 &nbsp;Admin Login</button>
        <button class="btn btn-secondary btn-full" style="padding:13px;font-size:15px" onclick="showPage('empLogin')">👤 &nbsp;Employee Login</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== ADMIN LOGIN ===== -->
<div id="adminLogin" class="page">
  <div class="container-sm">
    <div class="header"><div><h1>Admin Login</h1><p>SITS PTO Tracker</p></div></div>
    <div class="card">
      <div class="form-row"><label class="lbl">Password</label>
        <input type="password" id="adminPwInput" placeholder="Enter admin password" onkeydown="if(event.key==='Enter')doAdminLogin()">
      </div>
      <div id="adminLoginErr" class="error" style="display:none"></div>
      <div class="form-grid-2" style="margin-top:4px">
        <button class="btn btn-primary" onclick="doAdminLogin()">Login</button>
        <button class="btn btn-ghost" onclick="showPage('landing')">← Back</button>
      </div>
      <p class="hint" style="margin-top:10px;text-align:center">Default password: <strong>sits2026</strong></p>
    </div>
  </div>
</div>

<!-- ===== EMPLOYEE LOGIN ===== -->
<div id="empLogin" class="page">
  <div class="container-sm">
    <div class="header"><div><h1>Employee Login</h1><p>SITS PTO Tracker</p></div></div>
    <div class="card">
      <div class="form-row"><label class="lbl">Your Name</label>
        <select id="empLoginName"><option value="">Select your name...</option></select>
      </div>
      <div class="form-row"><label class="lbl">Password</label>
        <input type="password" id="empLoginPw" placeholder="Enter your password" onkeydown="if(event.key==='Enter')doEmpLogin()">
      </div>
      <div id="empLoginErr" class="error" style="display:none"></div>
      <div class="form-grid-2" style="margin-top:4px">
        <button class="btn btn-secondary" onclick="doEmpLogin()">Login</button>
        <button class="btn btn-ghost" onclick="showPage('landing')">← Back</button>
      </div>
      <p class="hint" style="margin-top:10px;text-align:center">Forgot your password? Contact your Engagement Manager at <strong><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="5a29332e291a292e3f3f36393b293f74393537">[email&#160;protected]</a></strong></p>
    </div>
  </div>
</div>

<!-- ===== EMPLOYEE DASHBOARD ===== -->
<div id="empDash" class="page">
  <div class="container">
    <div class="header">
      <div><h1 id="empDashName">My PTO</h1><p>Steelcase Integrated Talent Solutions</p></div>
      <button class="btn btn-back" onclick="logoutEmp()">← Logout</button>
    </div>

    <div class="tabs">
      <button class="tab active" onclick="switchTab('etBalance',this)">💰 My Balance</button>
      <button class="tab" onclick="switchTab('etRequest',this)">📅 Request PTO</button>
      <button class="tab" onclick="switchTab('etHistory',this)">📋 History</button>
      <button class="tab" onclick="switchTab('etAccount',this)">🔐 My Account</button>
    </div>

    <!-- BALANCE TAB -->
    <div id="etBalance" class="tab-content active">
      <div class="emp-profile">
        <div class="emp-name-lg" id="empProfileName"></div>
        <div class="stats-grid stats-3">
          <div class="stat-card">
            <div class="stat-value" id="empStatBalance">0.00</div>
            <div class="stat-label">Available PTO (hrs)</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="empStatHours">0</div>
            <div class="stat-label">Hours Worked</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="empStatRollover">72</div>
            <div class="stat-label">Rollover Cap (hrs)</div>
          </div>
        </div>
        <div class="rollover-info" id="empRolloverInfo"></div>
      </div>

      <div class="card">
        <div class="card-title">📊 Pending Requests</div>
        <div id="empPendingList"><div class="empty">No pending requests.</div></div>
      </div>
    </div>

    <!-- REQUEST PTO TAB -->
    <div id="etRequest" class="tab-content">
      <div class="card">
        <div class="card-title">📅 Submit a PTO Request</div>
        <p style="color:var(--muted);font-size:13px;margin-bottom:18px">Submit a future PTO request. If your projected balance is sufficient, it will be automatically approved.</p>
        <div class="form-grid-2">
          <div><label class="lbl">Start Date</label><input type="date" id="reqStartDate" oninput="estimatePTO()"></div>
          <div><label class="lbl">End Date</label><input type="date" id="reqEndDate" oninput="estimatePTO()"></div>
        </div>
        <div class="form-row"><label class="lbl">Hours to Request</label>
          <input type="number" id="reqHours" placeholder="e.g. 8 (full day), 4 (half day)" min="0.5" step="0.5" oninput="estimatePTO()">
        </div>
        <div class="form-row"><label class="lbl">Note (optional)</label>
          <input type="text" id="reqNote" placeholder="e.g. Vacation, personal day, doctor appointment...">
        </div>
        <div id="estimatorResult" style="display:none" class="estimator-result"></div>
        <button class="btn btn-secondary btn-full" style="margin-top:8px" onclick="submitPTORequest()">Submit Request</button>
      </div>

      <div class="card">
        <div class="card-title">🔮 Balance Estimator</div>
        <p style="color:var(--muted);font-size:13px;margin-bottom:14px">See your projected balance on any future date based on your current accrual rate.</p>
        <div class="form-grid-2">
          <div><label class="lbl">Future Date</label><input type="date" id="estimateDate" oninput="runEstimator()"></div>
          <div><label class="lbl">Additional Hours to Request</label><input type="number" id="estimateHours" placeholder="0" min="0" step="0.5" oninput="runEstimator()"></div>
        </div>
        <div id="estimatorOutput" style="display:none"></div>
      </div>
    </div>

    <!-- HISTORY TAB -->
    <div id="etHistory" class="tab-content">
      <div class="card">
        <div class="card-title">📋 Full History</div>
        <div id="empFullHistory"><div class="empty">No history yet.</div></div>
      </div>
    </div>

    <!-- ACCOUNT TAB -->
    <div id="etAccount" class="tab-content">
      <div class="card">
        <div class="card-title">🔐 Change My Password</div>
        <div class="form-row"><label class="lbl">Current Password</label><input type="password" id="empCurPw" placeholder="Current password"></div>
        <div class="form-grid-2">
          <div><label class="lbl">New Password</label><input type="password" id="empNewPw" placeholder="New password"></div>
          <div><label class="lbl">Confirm New Password</label><input type="password" id="empConfirmPw" placeholder="Confirm new password"></div>
        </div>
        <div id="empPwMsg" style="display:none"></div>
        <button class="btn btn-primary" style="margin-top:8px" onclick="changeEmpPassword()">Update Password</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== ADMIN DASHBOARD ===== -->
<div id="admin" class="page">
  <div class="container">
    <div class="header">
      <div><h1>Admin Dashboard</h1><p id="adminSubtitle">SITS PTO Tracker</p></div>
      <button class="btn btn-back" onclick="showPage('landing')">← Exit</button>
    </div>

    <div class="tabs">
      <button class="tab active" onclick="switchTab('aEmployees',this)">👥 Employees</button>
      <button class="tab" onclick="switchTab('aHours',this)">⏱️ Log Hours</button>
      <button class="tab" onclick="switchTab('aPTO',this)">🏖️ Log PTO</button>
      <button class="tab" onclick="switchTab('aRollover',this)">🔄 Rollover</button>
      <button class="tab" onclick="switchTab('aSettings',this)">⚙️ Settings</button>
    </div>

    <!-- EMPLOYEES TAB -->
    <div id="aEmployees" class="tab-content active">
      <div class="card">
        <div class="card-title">➕ Add New Employee</div>
        <div class="form-grid-4">
          <div><label class="lbl">Full Name</label><input type="text" id="newName" placeholder="Full name"></div>
          <div><label class="lbl">Anniversary Date</label><input type="date" id="newAnniv"></div>
          <div><label class="lbl">Starting PTO Balance</label><input type="number" id="newBalance" placeholder="0" min="0" step="0.01"></div>
          <div><label class="lbl">Password</label><input type="password" id="newPw" placeholder="Set password"></div>
          <div style="display:flex;align-items:flex-end"><button class="btn btn-primary" style="white-space:nowrap" onclick="addEmployee()">Add</button></div>
        </div>
        <p class="hint">Anniversary date determines when PTO rolls over annually (max 72 hours carried forward).</p>
      </div>

      <div class="card">
        <div class="card-title">👥 All Employees (<span id="empCount">0</span>)</div>
        <div class="tbl-wrap">
          <table>
            <thead><tr><th>Name</th><th>Anniversary</th><th>Hours Worked</th><th>PTO Balance</th><th>Next Rollover</th><th>Actions</th></tr></thead>
            <tbody id="empTable"><tr><td colspan="6" class="empty">No employees yet.</td></tr></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- LOG HOURS TAB -->
    <div id="aHours" class="tab-content">
      <div class="card">
        <div class="card-title">⏱️ Log Hours by Week</div>
        <p style="color:var(--muted);font-size:13px;margin-bottom:18px">Enter hours worked for a specific week ending date. PTO accrues automatically at the current rate (<span id="rateDisplay">0.0385</span> hrs PTO per hr worked).</p>
        <div class="form-grid-3">
          <div><label class="lbl">Employee</label><select id="accrualEmp" onchange="renderWeeklyLog()"><option value="">Select employee...</option></select></div>
          <div><label class="lbl">Week Ending Date</label><input type="date" id="accrualWeekEnd" oninput="previewAccrual()"></div>
          <div><label class="lbl">Hours Worked</label><input type="number" id="accrualHours" placeholder="e.g. 40" min="0" max="168" oninput="previewAccrual()"></div>
        </div>
        <div id="accrualPreview" style="display:none" class="alert alert-green"></div>
        <div id="accrualDupWarning" style="display:none" class="alert alert-yellow"></div>
        <button class="btn btn-primary btn-full" onclick="logHours()">Log Hours & Accrue PTO</button>
      </div>

      <div class="card">
        <div class="card-title">📋 Weekly Hours Log — <span id="weeklyEmpName" style="color:var(--mid);font-weight:400">Select an employee above</span></div>
        <div id="weeklyLog"><div class="empty">Select an employee to view their weekly hours log.</div></div>
      </div>
    </div>

    <!-- LOG PTO TAB -->
    <div id="aPTO" class="tab-content">
      <div class="card">
        <div class="card-title">🏖️ Log PTO (Admin Override)</div>
        <p style="color:var(--muted);font-size:13px;margin-bottom:18px">Manually record PTO — use for corrections or adjustments.</p>
        <div class="form-row"><label class="lbl">Employee</label><select id="ptoEmp"><option value="">Select employee...</option></select></div>
        <div class="form-grid-3">
          <div><label class="lbl">Hours</label><input type="number" id="ptoHours" placeholder="e.g. 8" min="0" step="0.5"></div>
          <div><label class="lbl">Date</label><input type="date" id="ptoDate"></div>
          <div><label class="lbl">Status</label>
            <select id="ptoStatus"><option value="Approved">Approved</option><option value="Pending">Pending</option><option value="Denied">Denied</option></select>
          </div>
        </div>
        <div class="form-row"><label class="lbl">Note</label><input type="text" id="ptoNote" placeholder="Reason or description..."></div>
        <button class="btn btn-secondary btn-full" onclick="logPTO()">Log PTO</button>
      </div>

      <div class="card">
        <div class="card-title">📋 Pending Employee Requests</div>
        <div id="adminPendingList"><div class="empty">No pending requests.</div></div>
      </div>
    </div>

    <!-- ROLLOVER TAB -->
    <div id="aRollover" class="tab-content">
      <div class="card">
        <div class="card-title">🔄 Process Annual Rollover</div>
